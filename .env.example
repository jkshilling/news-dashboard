# Non-secret values only. The OpenAI key is read on demand from the shared
# credentials file ~/Documents/Claude/.openai-key (mode 0600), so it does NOT
# live here. Process env OPENAI_API_KEY still wins if set (used by the droplet
# via its systemd EnvironmentFile).

DATABASE_URL=sqlite:///./data/app.db
APP_ENV=development
MAX_ARTICLES_PER_TOPIC=100
COLLECTION_INTERVAL_MINUTES=60
SYNTHESIS_INTERVAL_HOURS=24
SYNTHESIS_MIN_NEW_ARTICLES=3
REQUEST_TIMEOUT_SECONDS=20
USER_AGENT=NewsIntelDashboard/1.0
ENABLE_SCHEDULER=true
